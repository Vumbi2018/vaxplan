    "scripts": {
        "dev": "npx tsx --env-file=.env server/index.ts",
        "build": "tsx script/build.ts",
        "start": "npm run db:push && NODE_ENV=production node dist/index.cjs",
        "check": "tsc",
        "test": "vitest run",
        "db:push": "drizzle-kit push",
        "docs:pdf": "node scripts/build-user-guide-pdf.mjs",
        "build:android": "powershell -ExecutionPolicy Bypass -File scripts/Build-Android.ps1",
        "build:android:open": "powershell -ExecutionPolicy Bypass -File scripts/Build-Android.ps1 -Open",
        "build:android:release": "powershell -ExecutionPolicy Bypass -File scripts/Build-Android-Release.ps1",
        "build:android:all": "powershell -ExecutionPolicy Bypass -File scripts/Build-Android-All.ps1",
        "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/Build-Windows.ps1",
        "build:windows:all": "powershell -ExecutionPolicy Bypass -File scripts/Build-Windows-All.ps1",
        "cap:sync": "npm run build && npx cap sync",
        "cap:open:android": "npx cap open android",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5000 && npx electron electron-dist/main.js\"",
        "harvest:geonames": "npx tsx --env-file=.env scripts/harvest-geonames-communities.ts"
    },
