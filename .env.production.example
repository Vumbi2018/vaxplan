# ============================================================================
# VaxPlan — Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit the .env file itself to version control.
# ============================================================================

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Full Postgres connection string (overrides individual fields below)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Hostinger VPS PostgreSQL (alternative to DATABASE_URL)
HOSTINGER_DB_HOST=your-hostinger-postgresql-host.hostinger.com
HOSTINGER_DB_PORT=5432
HOSTINGER_DB_USER=your_db_user
HOSTINGER_DB_PASSWORD=your_db_password
HOSTINGER_DB_NAME=your_db_name

# ── Core App ─────────────────────────────────────────────────────────────────
NODE_ENV=production

# Port the Express server listens on
# IMPORTANT: Nginx on the VPS proxies vaxplan.org → localhost:5005
# If you change this, also update /etc/nginx/sites-enabled/vaxplan proxy_pass line
PORT=5005

SESSION_SECRET=change-me-to-a-strong-random-64-char-string

# Public URL of the deployed application (used in emails and version endpoint)
APP_URL=https://app.vaxplan.org

# ── Version (injected at build time by vite.config.ts) ───────────────────────
VITE_APP_VERSION=1.4.0
VITE_BUILD_DATE=2026-06-12
VITE_BUILD_TIME=14:00

# ── Email (Nodemailer — for approval/notification emails) ────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@vaxplan.org
SMTP_PASS=your_smtp_password
SMTP_FROM="VaxPlan <noreply@vaxplan.org>"

# ── SMS (Twilio — optional, for OTP / alert SMS) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Redis (BullMQ background job queues) ─────────────────────────────────────
# Leave blank to fall back to in-memory queue (not recommended for production)
REDIS_URL=redis://localhost:6379

# ── Hostinger Auto-Deploy Webhook ────────────────────────────────────────────
# Obtain from Hostinger Git settings panel
HOSTINGER_WEBHOOK_URL=https://hpanel.hostinger.com/api/git/deploy/your-unique-id

# ── Optional Integrations ────────────────────────────────────────────────────
# WorldPop API (population estimation — public, no key required currently)
# WORLDPOP_API_KEY=

# Mapbox token (if using Mapbox GL layers)
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@sentry.io/xxx
