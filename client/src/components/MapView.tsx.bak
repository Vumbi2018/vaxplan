// Updated Code: Responsive MapLegend accepting leftOffset prop to shift left-4 vs left-72 dynamically
interface MapLegendProps {
  leftOffset?: boolean;
}

function MapLegend({ leftOffset = false }: MapLegendProps) {
  return (
    <div className={`absolute ${leftOffset ? "left-72" : "left-4"} bottom-4 z-[1000] transition-all duration-300`}>
      <Card className="w-auto bg-background/95 backdrop-blur-md border border-border shadow-lg">
        <CardHeader className="p-3 pb-2">
          <CardTitle className="text-xs font-bold text-primary uppercase tracking-wider">Legend</CardTitle>
        </CardHeader>
        <CardContent className="p-3 pt-0 space-y-2">
          <div className="flex items-center gap-2">
            <div className="w-3 h-3 rounded-full bg-blue-500 shadow-sm" />
            <span className="text-xs font-medium text-foreground">Health Facility</span>
          </div>
          <div className="flex items-center gap-2">
            <div className="w-3 h-3 rounded-full bg-green-500 shadow-sm" />
            <span className="text-xs font-medium text-foreground">Community</span>
          </div>
          <div className="flex items-center gap-2">
            <div className="w-3 h-3 rounded-full bg-red-500 shadow-sm" />
            <span className="text-xs font-medium text-foreground">Hard to Reach</span>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}

/*
// Original Code (failed compile because typeof layers was used inside LayerPanelProps interface before the property was declared as a type, causing TypeScript to search for a variable named 'layers' which was not in scope)
